# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrimind
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Plant.id API (Disease Detection)
# Get your API key at: https://plant.id/
PLANT_ID_API_KEY=your_plantid_api_key_here

# Optional: OpenWeather API for weather-based crop recommendation
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000